---
// Shared architecture diagram — used on the home page and the /deep-dives page.
// Now a Mermaid flowchart (plain-text, editable) instead of hand-placed SVG.
// The one fact this diagram must get right: what crosses the device boundary to
// the frontier model — file ALIASES *and* the category TAG NAMES (never your
// files, your data, or your keyword rules).
import Mermaid from "./Mermaid.astro";

const chart = `flowchart TB
  FM["<b>Frontier model — cloud</b><br/>untrusted · sees only<br/>file aliases (file_0, col_2)<br/>+ category tag names (phone, travel…)"]
  subgraph mac["Your Mac — your data never leaves it"]
    direction TB
    CLIENT["browser / iOS<br/>the millfolio app"]
    APP["App server · :10000<br/>UI · REST · chat WS · launchd"]
    SAND["Generated Mojo program<br/>sandbox — loopback network only"]
    INF["Inference server · :8000<br/>chat + embeddings · on-device GPU · launchd"]
    VAULT["Your vault<br/>PDF · Word · CSV · notes<br/>LanceDB index · .tags on each txn"]
  end
  CLIENT -->|"HTTPS / WS"| APP
  APP -->|"question + aliased manifest + tag names"| FM
  FM -.->|"writes the program (aliases + tag names)"| SAND
  APP -->|"orchestrate · approval gate"| SAND
  SAND -->|"loopback HTTP · ask_local · search"| INF
  SAND -->|"reads files + .tags"| VAULT

  classDef box fill:rgba(255,255,255,0.04),stroke:rgba(159,180,194,0.30),color:#eaf1f6;
  classDef srv fill:rgba(255,255,255,0.04),stroke:rgba(255,122,28,0.55),color:#eaf1f6;
  classDef cloud fill:rgba(255,122,28,0.07),stroke:#ff7a1c,stroke-dasharray:4 4,color:#eaf1f6;
  classDef sand fill:rgba(255,255,255,0.03),stroke:#ff7a1c,stroke-dasharray:5 4,color:#eaf1f6;
  class CLIENT,VAULT box;
  class APP,INF srv;
  class FM cloud;
  class SAND sand;
  linkStyle 1,2 stroke:#ff7a1c,color:#ffb05c;`;
---

<Mermaid
  code={chart}
  label="millfolio architecture: the frontier model — which sees only file aliases and the category tag names — writes a program that runs in an on-device sandbox and reaches only the local inference server and your vault."
>
  What crosses the boundary to the cloud is deliberately thin: the
  <strong>aliased</strong> file manifest (<code>file_0</code>, <code>col_2</code>) and the
  category <strong>tag names</strong> (<code>phone</code>, <code>travel</code>…) — never
  your files, your data, or your keyword rules. The frontier-written program then runs as a
  <strong>separate, sandboxed process</strong> that can reach the network only over loopback
  — so inference is a <strong>local service</strong> it talks to over HTTP, not an in-process
  call. That's why there are two servers (and why they stay two: the app restarts without
  reloading the ~7&nbsp;GB model). Both run under <strong>launchd</strong>.
</Mermaid>

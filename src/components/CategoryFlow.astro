---
// Category-registry flow diagram — used on /deep-dives. Now a Mermaid flowchart
// (plain-text, editable) instead of hand-placed SVG, mirroring ArchDiagram.
// Story: tags are matched ONCE at index time by a deterministic, user-editable
// rule registry (built-in rules + your categories.txt); at query time the frontier
// model is told only the tag NAMES and writes a program that filters transactions()
// on `.tags`. The keyword rules + your data never leave the Mac, so the frontier
// model sits OUTSIDE the device boundary and the only cross-boundary edges carry
// tag NAMES (never your rules or data).
import Mermaid from "./Mermaid.astro";

const chart = `flowchart TB
  FM["<b>Frontier model — cloud</b><br/>untrusted · sees only<br/>the tag NAMES (phone, travel, pets…)"]
  subgraph mac["Your Mac — the rules and your data stay here"]
    direction TB
    Q["Your question<br/>“how much on phone?”"]
    PROG["Generated program<br/>sum(.amount) where<br/>“phone” in t.tags"]
    ANS["Your answer<br/>computed on-device"]
    subgraph idx["At index time — once, on-device, no model call"]
      direction LR
      STMT["Your statements<br/>PDF · CSV · OFX"]
      EXT["Extract<br/>reconciled txns"]
      REG["Category registry<br/>built-in rules<br/>+ your categories.txt"]
      TIDX["Tagged index<br/>.tags on each txn"]
    end
  end
  Q -->|"sends the tag NAMES + aliased manifest"| FM
  FM -.->|"writes the .tags filter"| PROG
  PROG -->|"exact filter over stored tags"| ANS
  STMT --> EXT
  EXT --> REG
  REG --> TIDX
  TIDX -->|"reads tagged txns"| PROG

  classDef box fill:rgba(255,255,255,0.04),stroke:rgba(159,180,194,0.30),color:#eaf1f6;
  classDef srv fill:rgba(255,255,255,0.04),stroke:rgba(255,122,28,0.55),color:#eaf1f6;
  classDef cloud fill:rgba(255,122,28,0.07),stroke:#ff7a1c,stroke-dasharray:4 4,color:#eaf1f6;
  classDef sand fill:rgba(255,255,255,0.03),stroke:#ff7a1c,stroke-dasharray:5 4,color:#eaf1f6;
  class Q,ANS,STMT,EXT,TIDX box;
  class REG srv;
  class FM cloud;
  class PROG sand;
  linkStyle 0,1 stroke:#ff7a1c,color:#ffb05c;`;
---

<Mermaid
  code={chart}
  label="How categories work: at index time a deterministic rule registry (built-in rules plus your categories.txt) tags every transaction in the on-device index; at query time the frontier model is told only the tag names and writes a program that filters transactions by tag. Keyword rules and your data never leave the Mac."
>
  Categories are <strong>rules, not guesses</strong>. A deterministic registry —
  the built-ins (<code>phone</code>, <code>travel</code>, <code>restaurant</code>,
  <code>groceries</code>, <code>health</code>) plus anything you add to
  <code>categories.txt</code> — tags every transaction <strong>once at index
  time</strong>, with no model call. So a category answer is a fast, exact filter
  over stored tags. The frontier model is told only the tag <strong>names</strong>
  (the vocabulary it can filter on) — never your keyword rules, which hold the
  merchant strings you typed and <strong>never leave the Mac</strong>.
</Mermaid>

---
const sysPrompt = "https://github.com/millfolio/vault/blob/main/privacy-box/resources/privacy_box-system.md";
const repo = "https://github.com/millfolio/vault";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Deep dive — millfolio</title>
    <meta
      name="description"
      content="How millfolio works under the hood: a question becomes a sandboxed program the frontier model writes but never gets to run against your data — with the actual generated Mojo."
    />
    <meta property="og:title" content="millfolio deep dive" />
    <meta
      property="og:description"
      content="A question becomes a program — frontier writes the code, your data stays home."
    />
    <meta property="og:type" content="article" />
    <meta property="og:url" content="https://millfolio.com/deep-dives" />
  </head>
  <body>
    <main>
      <header class="top">
        <a class="back" href="/">← millfolio</a>
        <a class="src" href={repo}>privacy box ↗</a>
      </header>

      <section class="intro">
        <span class="kicker">deep dive</span>
        <h1>A question becomes a program</h1>
        <p class="lede">
          millfolio lets a powerful <strong>remote</strong> model help with your
          private data without ever seeing it. The trick — the
          <a href="/privacy-box">privacy box</a> harness — is to treat the frontier
          model as an <strong>untrusted code generator, not a data
          processor</strong>. Here's how one question turns into code that runs on
          your Mac.
        </p>
      </section>

      <!-- ════════════════ privacy box ════════════════ -->
      <section class="prose" id="privacy-box">
        <h2>Two asymmetric models</h2>
        <p>
          There are two models, deliberately asymmetric:
        </p>
        <ul>
          <li>
            <strong>The frontier model</strong> (untrusted) is the planner/coder.
            It sees only a <em>sanitized manifest</em> of your vault — file
            <em>aliases</em> (<code>file_0</code>), kinds, aliased column schemas
            (<code>col_2</code>) — never contents, names, or values. From that it
            writes <strong>one Mojo program</strong> that calls a fixed set of
            vault tools.
          </li>
          <li>
            <strong>The local model</strong> (trusted, on your device) is the
            reader. When the program needs to understand content — "is this a
            travel expense?", "read the renewal date" — it calls
            <code>ask_local(...)</code>, which runs on the
            <a href="https://millfolio.com/server">millfolio inference engine</a> and
            is the only thing that ever sees real text.
          </li>
        </ul>
        <figure class="arch">
          <svg viewBox="0 0 760 470" role="img"
               aria-label="millfolio architecture: the frontier model writes a program that runs in an on-device sandbox and reaches only the local inference server and your vault.">
            <defs>
              <marker id="ar" markerWidth="9" markerHeight="9" refX="7" refY="3" orient="auto">
                <path d="M0,0 L7,3 L0,6 Z" fill="#9fb4c2" />
              </marker>
              <marker id="aro" markerWidth="9" markerHeight="9" refX="7" refY="3" orient="auto">
                <path d="M0,0 L7,3 L0,6 Z" fill="#ff7a1c" />
              </marker>
            </defs>
            <!-- frontier model — OUTSIDE the device boundary -->
            <rect class="cloud" x="470" y="8" width="278" height="50" rx="10" />
            <text class="t" x="609" y="29">Frontier model — cloud</text>
            <text class="s" x="609" y="46">untrusted · sees only aliases (file_0, col_2)</text>

            <!-- the on-device boundary: nothing real leaves the Mac -->
            <rect class="mac" x="8" y="74" width="744" height="388" rx="14" />
            <text class="badge" x="24" y="98">Your Mac — your data never leaves it</text>

            <!-- client -->
            <rect class="box" x="34" y="120" width="150" height="58" rx="10" />
            <text class="t" x="109" y="145">browser / iOS</text>
            <text class="s" x="109" y="163">the millfolio app</text>

            <!-- app server :10000 (launchd) -->
            <rect class="box srv" x="270" y="116" width="262" height="66" rx="10" />
            <text class="t" x="401" y="141">App server · :10000</text>
            <text class="s" x="401" y="159">UI · REST · chat WS</text>
            <text class="tag" x="401" y="175">launchd</text>

            <!-- generated program in the sandbox -->
            <rect class="box sand" x="270" y="246" width="262" height="74" rx="10" />
            <text class="t" x="401" y="271">Generated Mojo program</text>
            <text class="s" x="401" y="289">runs in a sandbox —</text>
            <text class="s" x="401" y="305">loopback network only</text>

            <!-- inference server :8000 (launchd) -->
            <rect class="box srv" x="34" y="372" width="258" height="74" rx="10" />
            <text class="t" x="163" y="397">Inference server · :8000</text>
            <text class="s" x="163" y="415">chat + embeddings · on-device GPU</text>
            <text class="tag" x="163" y="431">launchd</text>

            <!-- vault -->
            <rect class="box" x="470" y="372" width="248" height="74" rx="10" />
            <text class="t" x="594" y="397">Your vault</text>
            <text class="s" x="594" y="415">PDF · Word · CSV · notes</text>
            <text class="s" x="594" y="431">+ on-device LanceDB index</text>

            <!-- edges -->
            <line class="e" x1="184" y1="149" x2="266" y2="149" marker-end="url(#ar)" />
            <text class="el" x="225" y="141">HTTPS/WS</text>

            <line class="eo" x1="609" y1="58" x2="430" y2="242" marker-end="url(#aro)" stroke-dasharray="5 4" />
            <text class="elo" x="556" y="150">writes the program</text>
            <text class="elo" x="556" y="166">(aliases only)</text>

            <line class="e" x1="401" y1="182" x2="401" y2="242" marker-end="url(#ar)" />
            <text class="el" x="401" y="218">orchestrate · approval gate</text>

            <line class="eo" x1="330" y1="320" x2="200" y2="368" marker-end="url(#aro)" />
            <text class="elo" x="225" y="345">loopback HTTP</text>
            <text class="elo" x="225" y="360">ask_local · search</text>

            <line class="e" x1="470" y1="320" x2="560" y2="368" marker-end="url(#ar)" />
            <text class="el" x="556" y="346">reads files</text>
          </svg>
          <figcaption>
            One constraint shapes everything: the frontier-written program runs as a
            <strong>separate, sandboxed process</strong> that can reach the network only over
            loopback — so inference is a <strong>local service</strong> it talks to over HTTP, not
            an in-process call. That's why there are two servers (and why they stay two: the app
            restarts without reloading the ~7&nbsp;GB model). Both run under <strong>launchd</strong>.
          </figcaption>
        </figure>

        <p>
          The contract the frontier model is given is a single document — the
          <a href={sysPrompt}>privacy-box system prompt</a> — loaded at runtime. It
          spells out the confidentiality rules, the current Mojo dialect, and the
          tool surface (<code>search</code>, <code>csv_rows</code>,
          <code>pdf_text</code>, <code>docx_text</code>, <code>ask_local</code>, <code>print_answer</code>, …).
        </p>

        <h3>Example: a question becomes a program</h3>
        <p>
          You ask <em>"How much did I spend on travel last year?"</em>. The frontier
          model — seeing only aliases — writes this, and the privacy box compiles it and
          runs it in a sandbox that can reach only your local model:
        </p>
        <pre><code><span class="c"># written by the frontier model — it never sees a single real value</span>
from vault import *
def main() raises:
    var hits = search("travel transportation flights hotels expenses", 40)
    var total = 0.0
    for c in hits:
        <span class="c"># ask_local reads the REAL chunk on-device; returns "amount|yes" or "0|no"</span>
        var verdict = ask_local(
            "If this is a 2025 travel expense, reply '&lt;amount&gt;|yes', else '0|no'.", c.text)
        var parts = verdict.split("|")
        if len(parts) == 2 and String(parts[1]) == "yes":
            total += atof(String(parts[0]))
    print_answer("You spent about $" + String(total) + " on travel in 2025.")</code></pre>
        <p>
          The frontier model orchestrates over aliases; <code>search</code> and
          <code>ask_local</code> do the real work locally; the sum is computed on
          your machine and <code>print_answer</code> surfaces it there. The
          search results and the answer are <strong>never</strong> returned to the
          frontier model — which is exactly why the program model is load-bearing,
          not an implementation detail.
        </p>

        <h3>Why it holds</h3>
        <p>
          Containment lives <em>outside</em> the model, at the OS level. The
          generated program runs under a Seatbelt profile that <strong>denies all
          network except loopback</strong> to your local engine — it can't phone
          home. An egress guard gates every message to the frontier (fails closed),
          and the compile-feedback loop only ever sends back <em>aliased</em>
          source, never runtime output that might contain real content. Your
          documents never leave the Mac, and never reach the frontier model.
          See the <a href="/walkthrough">walkthrough</a> to try it, or
          <a href="/privacy-box">privacy box</a> for the full design.
        </p>
      </section>

      <footer>
        <span>© millfolio</span>
        <span class="dot">·</span>
        <a href="/privacy-box">privacy box →</a>
        <span class="dot">·</span>
        <a href="https://millfolio.com">runs on millfolio ↗</a>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  :root {
    --bg-top: #284a5c;
    --bg-bot: #122632;
    --ink: #eaf1f6;
    --muted: #9fb4c2;
    --accent: #ff7a1c;
    --accent-lite: #ffb05c;
    --line: rgba(159, 180, 194, 0.18);
    --card: rgba(255, 255, 255, 0.035);
  }

  * { box-sizing: border-box; }
  html { color-scheme: dark; scroll-behavior: smooth; }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    background:
      radial-gradient(1200px 600px at 50% -10%, rgba(255, 122, 28, 0.10), transparent 60%),
      linear-gradient(180deg, var(--bg-top), var(--bg-bot));
    background-attachment: fixed;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto,
      Helvetica, Arial, sans-serif;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a { color: var(--accent-lite); text-decoration: none; }
  a:hover { text-decoration: underline; }

  main { max-width: 760px; margin: 0 auto; padding: clamp(2rem, 5vw, 4rem) 1.5rem 3rem; }

  .top { display: flex; justify-content: space-between; margin-bottom: 2rem; }
  .back, .src { color: var(--muted); font-weight: 600; font-size: 0.95rem; }
  .back:hover, .src:hover { color: var(--accent-lite); }

  .kicker {
    text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 0.78rem; font-weight: 700; color: var(--accent-lite);
  }
  h1 {
    font-size: clamp(2rem, 6vw, 3rem); letter-spacing: -0.03em;
    margin: 0.5rem 0 0; font-weight: 700;
    background: linear-gradient(180deg, #ffffff, #cedae6);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .lede { margin: 1.2rem 0 0; color: var(--muted); font-size: 1.1rem; }
  .lede strong, .prose strong, li strong { color: var(--ink); }

  .prose { margin-top: clamp(2.5rem, 6vw, 3.5rem); scroll-margin-top: 1.5rem; }
  .prose h2 {
    font-size: 1.7rem; letter-spacing: -0.02em; margin: 0 0 0.8rem;
    padding-bottom: 0.4rem; border-bottom: 1px solid var(--line);
  }
  .prose h3 { font-size: 1.15rem; margin: 1.8rem 0 0.4rem; color: var(--ink); }
  .prose p { color: var(--muted); }
  .prose ul { color: var(--muted); padding-left: 1.2rem; }
  .prose li { margin: 0.55rem 0; }
  .note { font-size: 0.95rem; }

  pre {
    background: rgba(0, 0, 0, 0.28); border: 1px solid var(--line);
    border-radius: 10px; padding: 1rem 1.1rem; overflow-x: auto;
    font-size: 0.82rem; line-height: 1.7; margin: 1.2rem 0;
  }
  code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.92em; }
  p code, li code, .note code, td code {
    background: rgba(255, 255, 255, 0.06); border: 1px solid var(--line);
    border-radius: 5px; padding: 0.05rem 0.35rem; color: var(--ink);
  }
  pre code { background: none; border: 0; padding: 0; color: var(--ink); }
  pre .c { color: var(--muted); }

  footer {
    margin-top: clamp(3rem, 8vw, 5rem); padding-top: 1.5rem;
    border-top: 1px solid var(--line); text-align: center;
    color: var(--muted); font-size: 0.9rem;
  }
  footer a { color: var(--muted); }
  footer a:hover { color: var(--accent-lite); }
  .dot { margin: 0 0.5rem; opacity: 0.5; }

  /* ── architecture diagram ── */
  .arch { margin: 1.8rem 0 0.4rem; }
  .arch svg { width: 100%; height: auto; display: block; }
  .arch figcaption {
    margin: 0.7rem 0 0; color: var(--muted); font-size: 0.92rem; line-height: 1.55;
  }
  .arch figcaption strong { color: var(--ink); }
  /* boxes */
  .arch .box { fill: var(--card); stroke: var(--line); stroke-width: 1; }
  .arch .srv { stroke: rgba(255, 122, 28, 0.5); }
  .arch .sand { stroke: rgba(255, 122, 28, 0.5); stroke-dasharray: 5 4; }
  .arch .mac { fill: rgba(255, 255, 255, 0.015); stroke: var(--line); stroke-width: 1.5; }
  .arch .cloud { fill: rgba(255, 255, 255, 0.02); stroke: var(--line); stroke-width: 1; stroke-dasharray: 4 4; }
  /* text */
  .arch .t { fill: var(--ink); font-size: 14px; font-weight: 600; text-anchor: middle; }
  .arch .s { fill: var(--muted); font-size: 11.5px; text-anchor: middle; }
  .arch .badge { fill: var(--muted); font-size: 11px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
  .arch .tag {
    fill: var(--accent-lite); font-size: 10px; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase; text-anchor: middle;
  }
  /* edges */
  .arch .e { stroke: var(--muted); stroke-width: 1.4; opacity: 0.7; }
  .arch .eo { stroke: var(--accent); stroke-width: 1.6; }
  .arch .el { fill: var(--muted); font-size: 10.5px; text-anchor: middle; }
  .arch .elo { fill: var(--accent-lite); font-size: 10.5px; text-anchor: middle; }
</style>

---
const tools = [
  {
    name: "jinja2.mojo",
    desc: "A minimal implementation of Jinja2 in Mojo — used to render the Qwen2.5 chat template byte-identically to transformers.apply_chat_template.",
    href: "https://github.com/millfolio/jinja2.mojo",
    tag: "templating",
  },
  {
    name: "zlib.mojo",
    desc: "A Mojo zlib binding (inflate/deflate) via a thin C shim to libz. Powers PDF /FlateDecode in pdftotext.mojo and general decompression.",
    href: "https://github.com/millfolio/zlib.mojo",
    tag: "compression",
  },
  {
    name: "pdftotext.mojo",
    desc: "A pure-Mojo PDF text extractor — object map, page-tree walk, content-stream text ops, and /ToUnicode CMap decoding. Pulls clean text out of PDFs for document pipelines.",
    href: "https://github.com/millfolio/pdftotext.mojo",
    tag: "pdf",
  },
  {
    name: "docx.mojo",
    desc: "A from-scratch Word .docx text extractor in Mojo — unzips the OOXML package (reusing zlib.mojo for DEFLATE) and scans word/document.xml for the text runs. Pulls clean text out of .docx for document pipelines.",
    href: "https://github.com/millfolio/docx.mojo",
    tag: "docx",
  },
  {
    name: "lancedb.mojo",
    desc: "A Mojo binding for the LanceDB vector store via a small Rust cdylib over a C ABI. An on-device vector index for embedding search.",
    href: "https://github.com/millfolio/lancedb.mojo",
    tag: "vector store",
  },
  {
    name: "csv.mojo",
    desc: "A from-scratch RFC-4180 CSV parser in Mojo — quoted fields, embedded commas/newlines, escaped quotes, UTF-8-safe. General-purpose CSV parsing.",
    href: "https://github.com/millfolio/csv.mojo",
    tag: "parsing",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Tools — millfolio</title>
    <meta
      name="description"
      content="The small, single-purpose Mojo libraries millfolio builds and maintains — chat templating, compression, PDF extraction, and an on-device vector store — plus the flare networking stack we build on."
    />
    <meta property="og:title" content="millfolio tools" />
    <meta
      property="og:description"
      content="The small, single-purpose Mojo libraries millfolio builds and maintains, plus the flare networking stack we build on."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://millfolio.com/tools" />
  </head>
  <body>
    <main>
      <header class="top">
        <a class="back" href="/"><img src="/logo.png" alt="" width="18" height="18" style="vertical-align:-3px;border-radius:4px;margin-right:6px" />← <span class="brand-name">millfolio</span></a>
        <a class="src" href="https://github.com/millfolio">github.com/millfolio ↗</a>
      </header>

      <section class="intro">
        <span class="kicker">the toolbox</span>
        <h1>Small libraries, sharp edges</h1>
        <p class="lede">
          Building the stack from scratch in <a href="https://www.modular.com/mojo">Mojo</a>
          meant writing the pieces that didn't exist yet. Each is a small,
          single-purpose library — usable on its own, and together the substrate
          under <a href="/server">the server</a>.
        </p>
      </section>

      <section class="projects">
        {
          tools.map((t) => (
            <a class="card" href={t.href}>
              <div class="card-head">
                <span class="card-name">{t.name}</span>
                <span class="card-tag">{t.tag}</span>
              </div>
              <p class="card-desc">{t.desc}</p>
            </a>
          ))
        }
      </section>

      <section class="prose">
        <h2>Networking: flare</h2>
        <p>
          The HTTP and TLS under the inference server is
          <a href="https://github.com/ehsanmok/flare">flare</a>, a full
          networking stack for Mojo (HTTP/1.1 and HTTP/2, WebSocket, TLS, TCP/UDP)
          on a single non-blocking reactor. We build on flare and maintain a
          <a href="https://github.com/millfolio/flare">fork at
          <code>millfolio/flare</code></a> to track the nightly Mojo dialect and
          the FFI fixes our shims depend on, upstreaming where we can.
        </p>
      </section>

      <footer>
        <span>© <span class="brand-name">millfolio</span></span>
        <span class="dot">·</span>
        <a href="https://github.com/millfolio">github.com/millfolio</a>
        <span class="dot">·</span>
        <a href="/">← home</a>
      </footer>
    </main>
    <script is:inline>
      // Brand follows the domain: millfolio.* → millfolio, millfoil.* → millfoil
      // (registrable name = second-to-last DNS label; fallback millfolio). Rewrites
      // .brand-name elements + the title at load. Guarded so the default millfolio
      // domain renders statically with no flash.
      (function () {
        var labels = location.hostname.split(".").filter(Boolean);
        var sld = labels.length >= 2 ? labels[labels.length - 2] : "";
        var brand = /^[a-z]/i.test(sld) ? sld : "millfolio";
        if (brand === "millfolio") return;
        var cap = brand.charAt(0).toUpperCase() + brand.slice(1);
        var sub = function (s) {
          return s.replace(/Millfolio/g, cap).replace(/millfolio/g, brand);
        };
        document.title = sub(document.title);
        document.querySelectorAll(".brand-name").forEach(function (el) {
          el.textContent = sub(el.textContent);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg-top: #284a5c;
    --bg-bot: #122632;
    --ink: #eaf1f6;
    --muted: #9fb4c2;
    --accent: #ff7a1c;
    --accent-lite: #ffb05c;
    --line: rgba(159, 180, 194, 0.18);
    --card: rgba(255, 255, 255, 0.035);
    --card-hover: rgba(255, 255, 255, 0.07);
  }

  * { box-sizing: border-box; }
  html { color-scheme: dark; }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    background:
      radial-gradient(1200px 600px at 50% -10%, rgba(255, 122, 28, 0.10), transparent 60%),
      linear-gradient(180deg, var(--bg-top), var(--bg-bot));
    background-attachment: fixed;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto,
      Helvetica, Arial, sans-serif;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a { color: var(--accent-lite); text-decoration: none; }
  a:hover { text-decoration: underline; }

  main {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem) 1.5rem 3rem;
  }

  .top { display: flex; justify-content: space-between; margin-bottom: 2rem; }
  .back, .src { color: var(--muted); font-weight: 600; font-size: 0.95rem; }
  .back:hover, .src:hover { color: var(--accent-lite); }

  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent-lite);
  }

  h1 {
    font-size: clamp(2rem, 6vw, 3rem);
    letter-spacing: -0.03em;
    margin: 0.5rem 0 0;
    font-weight: 700;
    background: linear-gradient(180deg, #ffffff, #cedae6);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .lede {
    margin: 1.2rem 0 0;
    color: var(--muted);
    font-size: 1.1rem;
  }
  .lede strong { color: var(--ink); }

  /* ── tool cards ─────────────────────────────────────────── */
  .projects {
    margin-top: clamp(2.5rem, 6vw, 3.5rem);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .card {
    display: block;
    padding: 1.25rem 1.4rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--card);
    color: var(--ink);
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.1s ease;
  }
  .card:hover {
    background: var(--card-hover);
    border-color: rgba(255, 122, 28, 0.45);
    text-decoration: none;
    transform: translateY(-2px);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .card-name { font-weight: 700; font-size: 1.1rem; }
  .card-tag {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-lite);
    border: 1px solid rgba(255, 122, 28, 0.3);
    border-radius: 999px;
    padding: 0.12rem 0.6rem;
    white-space: nowrap;
  }
  .card-desc { margin: 0.6rem 0 0; color: var(--muted); font-size: 0.95rem; }

  /* ── prose ──────────────────────────────────────────────── */
  .prose { margin-top: clamp(2.5rem, 6vw, 3.5rem); }
  .prose h2 {
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    margin: 0 0 0.8rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--line);
  }
  .prose p { color: var(--muted); }
  p code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.92em;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.05rem 0.35rem;
    color: var(--ink);
  }

  footer {
    margin-top: clamp(3rem, 8vw, 5rem);
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    text-align: center;
    color: var(--muted);
    font-size: 0.9rem;
  }
  footer a { color: var(--muted); }
  footer a:hover { color: var(--accent-lite); }
  .dot { margin: 0 0.5rem; opacity: 0.5; }
</style>
